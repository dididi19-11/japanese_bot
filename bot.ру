def get_or_create_user(user_id, username):
    result = supabase.table('users').select('*').eq('user_id', user_id).execute()
    if result.data:
        return result.data[0]
    else:
        new_user = {
            'user_id': user_id,
            'username': username or "unknown",
            'level': 'N5',
            'current_lesson': 1,
            'learned_kanji': ['日', '月'],
            'next_kanji': '火',
            'relationship_score': 3,
            'dialogue_count': 0,
            'mistakes': []
        }
        supabase.table('users').insert(new_user).execute()
        return new_user

def update_user(user_id, updates):
    supabase.table('users').update(updates).eq('user_id', user_id).execute()

@bot.message_handler(func=lambda m: True)
def handle_message(message):
    user_id = str(message.from_user.id)
    username = message.from_user.username
    profile = get_or_create_user(user_id, username)

    prompt = f"""Ты — учитель японского Кири.
Урок {profile['current_lesson']}, иероглиф: {profile['next_kanji']}
Выучено: {', '.join(profile['learned_kanji'])}
Отношения: {profile['relationship_score']}/10

Не используй другие иероглифы, отвечай кратко.

Сообщение: {message.text}"""

    response = deepseek.chat.completions.create(
        model="deepseek-chat",
        messages=[{"role": "user", "content": prompt}],
        temperature=0.3
    )
    answer = response.choices[0].message.content

    update_user(user_id, {'dialogue_count': profile.get('dialogue_count', 0) + 1})
    bot.reply_to(message, answer)

print("✅ Бот запущен!")
